<% append_stylesheet_pack_tag "decidim_extra_user_fields_css" %>
<% append_javascript_pack_tag "decidim_extra_user_fields" %>
<% add_decidim_page_title(t("decidim.admin.extra_user_fields.benchmarking.title")) %>
<div class="insights-page">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t("decidim.admin.extra_user_fields.benchmarking.title") %>
    </h1>
  </div>

  <div class="mb-4">
    <p class="help-text"><%= t("decidim.admin.extra_user_fields.benchmarking.select_spaces") %></p>
  </div>

  <%= render partial: "decidim/extra_user_fields/admin/benchmarking/selectors" %>

  <div class="mt-4">
    <% if selected_spaces.empty? %>
      <div class="card">
        <div class="card-section">
          <p class="help-text"><%= t("decidim.admin.extra_user_fields.benchmarking.select_spaces_prompt") %></p>
        </div>
      </div>
    <% elsif comparative_pivot_presenter.empty? %>
      <div class="card">
        <div class="card-section">
          <p class="help-text"><%= t("decidim.admin.extra_user_fields.benchmarking.no_data") %></p>
        </div>
      </div>
    <% else %>
      <%= render partial: "decidim/extra_user_fields/admin/benchmarking/comparison_table" %>
    <% end %>
  </div>
</div>
